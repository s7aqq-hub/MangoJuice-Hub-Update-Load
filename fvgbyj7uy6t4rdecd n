local Connections = {}
local CharAddedConnections = {}
local Originals = {}

local function SetHitbox(player)
    if player == LocalPlayer or Connections[player] then
        return
    end

    Connections[player] = RunService.RenderStepped:Connect(function()
        if not _G.Config.Hitbox.Enabled then return end

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        if not Originals[player] then
            Originals[player] = {
                Size = hrp.Size,
                Color = hrp.Color,
                Transparency = hrp.Transparency,
                CanCollide = hrp.CanCollide
            }
        end

        local size = _G.Config.Hitbox.Size or 50

        hrp.Size = Vector3.new(size, size, size)
        hrp.Color = HITBOX_COLOR
        hrp.Transparency = HITBOX_ALPHA
        hrp.CanCollide = false
    end)
end

local function WatchCharacter(player)
    if CharAddedConnections[player] then return end

    CharAddedConnections[player] = player.CharacterAdded:Connect(function()
        task.wait(0.2)
        Originals[player] = nil
        if _G.Config.Hitbox.Enabled then
            SetHitbox(player)
        end
    end)
end

local function EnableHitbox()
    _G.Config.Hitbox.Enabled = true

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            SetHitbox(player)
            WatchCharacter(player)
        end
    end
end

local function DisableHitbox()
    _G.Config.Hitbox.Enabled = false

    for _, conn in pairs(Connections) do
        if conn then conn:Disconnect() end
    end

    for player, data in pairs(Originals) do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and data then
            hrp.Size = data.Size
            hrp.Color = data.Color
            hrp.Transparency = data.Transparency
            hrp.CanCollide = data.CanCollide
        end
    end

    for _, conn in pairs(CharAddedConnections) do
        if conn then conn:Disconnect() end
    end

    table.clear(Connections)
    table.clear(Originals)
    table.clear(CharAddedConnections)
end

_G.Config = {

