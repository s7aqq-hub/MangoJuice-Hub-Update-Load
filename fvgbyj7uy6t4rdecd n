local function Aimbot_GetDistanceSquared(pos1, pos2)
    return (pos1 - pos2).Magnitude^2
end

local function Aimbot_GetNearestPlayer()
    local closestPlayer = nil
    local maxDistanceSq = _G.Config.Aimbot.Distance * _G.Config.Aimbot.Distance
    local shortestDistance = maxDistanceSq

    local myCharacter = LocalPlayer.Character
    if not myCharacter or not myCharacter:FindFirstChild("HumanoidRootPart") then
        return nil
    end

    local root = myCharacter.HumanoidRootPart
    local myPosition = root.Position
    local hum = Players.Character:FindFirstChild("Humanoid")


    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer
        and player.Character
        and hum and hum.Health > 0 then

            local targetPos = player.Character.HumanoidRootPart.Position
            local distance = Aimbot_GetDistanceSquared(myPosition, targetPos)

            if distance < shortestDistance then
                shortestDistance = distance
                closestPlayer = player
            end
        end
    end

    if closestPlayer then
        local targetPos = closestPlayer.Character.HumanoidRootPart.Position

        local lookAtPosition = Vector3.new(
            targetPos.X,
            myPosition.Y,
            targetPos.Z
        )

        root.CFrame = CFrame.new(myPosition, lookAtPosition)

        return targetPos
    end

    return nil
end

local function Aimbot_GetPlayerList()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(list, plr.Name)
        end
    end
    return list
end

local function Aimbot_StopAll()
    if Aimbot_SelectedAimConnection then
        Aimbot_SelectedAimConnection:Disconnect()
        Aimbot_SelectedAimConnection = nil
    end

    if Aimbot_NearestAimConnection then
        Aimbot_NearestAimConnection:Disconnect()
        Aimbot_NearestAimConnection = nil
    end
end

