function fm:EnableNoClip()
    if not self.ch then return end

    if self._NoClipConnection then
        self._NoClipConnection:Disconnect()
    end

    for _, x in ipairs(self.ch:GetDescendants()) do
        if x:IsA("BasePart") then
            x.CanCollide = false
            pcall(function() x.CollisionGroup = "NoCollision" end)
        end
    end

    self._NoClipConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if not self.ch then return end
        for _, x in ipairs(self.ch:GetDescendants()) do
            if x:IsA("BasePart") then

                if x.CanCollide then
                    x.CanCollide = false
                    pcall(function() x.CollisionGroup = "NoCollision" end)
                end
            end
        end
    end)
end

function fm:DisableNoClip()
    if self._NoClipConnection then
        self._NoClipConnection:Disconnect()
        self._NoClipConnection = nil
    end
    if not self.ch then return end
    for _, x in ipairs(self.ch:GetDescendants()) do
        if x:IsA("BasePart") then
            x.CanCollide = true
            pcall(function() x.CollisionGroup = "Default" end)
        end
    end
end

