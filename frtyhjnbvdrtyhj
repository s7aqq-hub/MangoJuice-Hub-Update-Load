local function startFollow()
    if FPSCon then
        FPSCon:Disconnect()
        FPSCon = nil
    end
    
    FPSCon = RunService.RenderStepped:Connect(function(dt)
        local FPS = 1/dt
    
        if FPS > 120 then
            SlowFollowSpeed = 300
        elseif FPS < 120 then
            SlowFollowSpeed = 350
        end
    end)

    local CloseRangeSuperSpeed = 300000000000000000000000000000000000000000E99

    if followConnection then 
        followConnection:Disconnect() 
    end

    followConnection = RunService.Heartbeat:Connect(function(dt)
        if not (_G.Config.Teleport.Enabled.ToPlayer or _G.Config.Teleport.Enabled.Bypass) then 
            return 
        end
        if not _G.Config.Teleport.Settings.SelectPlayer then 
            return 
        end

        local target = Players:FindFirstChild(_G.Config.Teleport.Settings.SelectPlayer)
        if not target or not target.Character then 
            return 
        end

        local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if not targetHRP then 
            return 
        end

        local char = LocalPlayer.Character
        if not char then 
            return 
        end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then 
            return 
        end

        if _G.Config.WalkSpeed.Enabled then
            WalkSpeedStop()
        end

        if _G.Config.Teleport.Enabled and fm then
            fm:EnableNoClip()
        end

        local targetPos = targetHRP.Position + Vector3.new(
            _G.Config.Teleport.Settings.OffsetX,
            _G.Config.Teleport.Settings.OffsetY,
            _G.Config.Teleport.Settings.OffsetZ
        )

        hrp.CFrame = CFrame.new(
            hrp.Position.X,
            targetPos.Y,
            hrp.Position.Z
        )

        local flatDir = Vector3.new(
            targetPos.X - hrp.Position.X,
            0,
            targetPos.Z - hrp.Position.Z
        )

        if flatDir.Magnitude > 0.1 then
            if _G.Config.Teleport.Enabled.ToPlayer then
                local distance = flatDir.Magnitude
                local currentSpeed = (distance < 100) and CloseRangeSuperSpeed or SlowFollowSpeed
                local moveStep = math.max(3, currentSpeed * dt)
                local moveVector = flatDir.Unit * math.min(moveStep, distance)

                hrp.CFrame = CFrame.new(hrp.Position + moveVector)

            elseif _G.Config.Teleport.Enabled.Bypass then
                    hrp.CFrame = CFrame.new(
                        targetPos.X,
                        targetPos.Y,
                        targetPos.Z
                    )
            end
        end
    end)
end

