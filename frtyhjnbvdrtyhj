local function Aimbot_GetNearestPlayer()
    local closestPlayer = nil
    local maxDistanceSq = _G.Config.Aimbot.Distance * _G.Config.Aimbot.Distance
    local shortestDistance = maxDistanceSq

    local myCharacter = LocalPlayer.Character
    if not myCharacter or not myCharacter:FindFirstChild("HumanoidRootPart") then
        return nil
    end

    local root = myCharacter.HumanoidRootPart
    local myPosition = root.Position

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer
        and player.Character
        and player.Character:FindFirstChild("HumanoidRootPart") then

            local targetPos = player.Character.HumanoidRootPart.Position
            local distance = Aimbot_GetDistanceSquared(myPosition, targetPos)

            if distance < shortestDistance then
                shortestDistance = distance
                closestPlayer = player
            end
        end
    end

    if closestPlayer then
        local targetPos = closestPlayer.Character.HumanoidRootPart.Position

        -- ⭐ 直接在這裡讓角色朝向目標
        local lookAtPosition = Vector3.new(
            targetPos.X,
            myPosition.Y, -- 保持水平
            targetPos.Z
        )

        root.CFrame = CFrame.new(myPosition, lookAtPosition)

        return targetPos
    end

    return nil
end

