    Callback = function(state)
        if Teleporting then return end
        if not state then return end

        if not _G.Config.Teleport.Settings.SelectIsland or not Maps[CurrentSea][_G.Config.Teleport.Settings.SelectIsland] then
            WindUI:Notify({
                Title = "MangoJuice Hub Notify",
                Content = "Please Select Island",
                Icon = "solar:bell-bold",
                Duration = 5
            })
            task.delay(0.3, function() TeleportIsland:Set(false) end)
            return
        end

        local character = Player.Character or Player.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart")
        local targetPos = Maps[CurrentSea][_G.Config.Teleport.Settings.SelectIsland]
        local distance = (hrp.Position - targetPos).Magnitude

        if distance < 1000 then
            WindUI:Notify({
                Title = "MangoJuice Hub Notify",
                Content = "You are already on this island",
                Icon = "solar:bell-bold",
                Duration = 5
            })
            task.delay(0.3, function() TeleportIsland:Set(false) end)
            return
        end

        WindUI:Notify({
            Title = "MangoJuice Hub Notify",
            Content = "Teleporting.....\n\nYour camera will have locked to bypass anti cheat",
            Icon = "solar:bell-bold",
            Duration = 10
        })

        doTeleport()

        if RespawnConnection then
            RespawnConnection:Disconnect()
            RespawnConnection = nil
        end

        RespawnConnection = Player.CharacterAdded:Connect(function(char)
            task.wait(1)
            local NewHRP = char:WaitForChild("HumanoidRootPart")
            local NewDistance = (NewHRP.Position - targetPos).Magnitude

            if NewDistance > 500 and not Teleporting then
                WindUI:Notify({
                    Title = "MangoJuice Hub Notify",
                    Content = "Teleport Failed\n\nTeleport Again.....",
                    Icon = "solar:bell-bold",
                    Duration = 10
                })
                task.wait(2)
                doTeleport()
            else
                WindUI:Notify({
                    Title = "MangoJuice Hub Notify",
                    Content = "Teleport Completed !",
                    Icon = "solar:bell-bold",
                    Duration = 5
                })

                task.delay(0.3, function()
                    TeleportIsland:Set(false)
                end)

                if RespawnConnection then
                    RespawnConnection:Disconnect()
                    RespawnConnection = nil
                end
            end
        end)
    end
})

