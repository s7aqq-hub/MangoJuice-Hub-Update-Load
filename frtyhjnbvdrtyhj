local function doTeleport()
    if Teleporting then return end
    if not _G.Config.Teleport.Settings.SelectIsland then return end

    Teleporting = true
    lockCameraWhileTeleport(4)

    local character = Player.Character or Player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local hrp = character:WaitForChild("HumanoidRootPart")

    local chosenPos = Maps[CurrentSea][_G.Config.Teleport.Settings.SelectIsland]
    if not chosenPos then
        Teleporting = false
        return
    end

    local playerPos = hrp.Position
    local distanceToChosen = (chosenPos - playerPos).Magnitude

    local requireRelay = false
    if ThirdSea then
        requireRelay = true
    elseif SecondSea then
        requireRelay = distanceToChosen > MAX_DIRECT_DISTANCE
    end

    local MIN_DISTANCE_FROM_CURRENT = 500

    if requireRelay then
        local relayPos
        local bestDiff
        for name, pos in pairs(Maps[CurrentSea]) do
            if name ~= _G.Config.Teleport.Settings.SelectIsland then
                local d1 = (pos - playerPos).Magnitude
                local d2 = (chosenPos - pos).Magnitude
                if d1 >= MIN_DISTANCE_FROM_CURRENT then
                    local diff = math.abs(d1 - d2)
                    if not bestDiff or diff < bestDiff then
                        bestDiff = diff
                        relayPos = pos
                    end
                end
            end
        end

        if relayPos then
            for i = 1, SeaTP do
                hrp.CFrame = CFrame.new(relayPos)
                RunService.RenderStepped:Wait()
            end
        end

        local bridgePos
        local bestScore
        for name, pos in pairs(Maps[CurrentSea]) do
            if pos ~= relayPos and name ~= _G.Config.Teleport.Settings.SelectIsland then
                local dRelay = (pos - relayPos).Magnitude
                local dChosen = (chosenPos - pos).Magnitude
                if (pos - playerPos).Magnitude >= MIN_DISTANCE_FROM_CURRENT then
                    local score = dRelay + dChosen
                    if not bestScore or score < bestScore then
                        bestScore = score
                        bridgePos = pos
                    end
                end
            end
        end

        if bridgePos then
            for i = 1, SeaTP2 do
                hrp.CFrame = CFrame.new(bridgePos)
                RunService.RenderStepped:Wait()
            end
        end

        humanoid.Health = 0
        character = waitForRespawn()
        humanoid = character:WaitForChild("Humanoid")
        hrp = character:WaitForChild("HumanoidRootPart")
        playerPos = hrp.Position
    end

    local secondPos
    local closestDist
    for name, pos in pairs(Maps[CurrentSea]) do
        if name ~= _G.Config.Teleport.Settings.SelectIsland then
            local dist = (pos - playerPos).Magnitude
            if dist >= MIN_DISTANCE_FROM_PLAYER and dist >= MIN_DISTANCE_FROM_CURRENT then
                if not closestDist or dist < closestDist then
                    closestDist = dist
                    secondPos = pos
                end
            end
        end
    end

    task.wait(0.6)
    lockCameraWhileTeleport(4)

    if secondPos then
        for i = 1, SeaTP do
            hrp.CFrame = CFrame.new(secondPos)
            RunService.RenderStepped:Wait()
        end
    end

    for i = 1, SeaTP2 do
        hrp.CFrame = CFrame.new(chosenPos)
        RunService.RenderStepped:Wait()
    end

    humanoid.Health = 0
    Teleporting = false
end

