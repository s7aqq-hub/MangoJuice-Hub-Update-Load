local function getRemote()
    local char = player.Character
    local backpack = player:FindFirstChild("Backpack")
    local tool

    if char then
        if _G.Config.FastAttack.KitsuneAttack then
            tool = char:FindFirstChild("Kitsune-Kitsune")
        elseif _G.Config.FastAttack.DragonAttack then
            tool = char:FindFirstChild("Dragon-Dragon")
        elseif _G.Config.FastAttack.GasAttack then
            tool = char:FindFirstChild("Gas-Gas")
        end

        if tool then
            return tool:FindFirstChild("LeftClickRemote", true)
        end
    end

    if backpack then
        if _G.Config.FastAttack.KitsuneAttack then
            tool = backpack:FindFirstChild("Kitsune-Kitsune")
        elseif _G.Config.FastAttack.DragonAttack then
            tool = backpack:FindFirstChild("Dragon-Dragon")
        elseif _G.Config.FastAttack.GasAttack then
            tool = backpack:FindFirstChild("Gas-Gas")
        end
        if tool then
            return tool:FindFirstChild("LeftClickRemote", true)
        end
    end
end

