local function BuildFastAttack()
    local FastAttack = {}

    local function CollectEnemies(list, folder)
        if not folder then return end

        for _, enemy in ipairs(folder:GetChildren()) do
            if enemy ~= Player.Character and IsAlive(enemy) then
                local part = GetRandomValidPart(enemy)
                if part and Player:DistanceFromCharacter(part.Position) <= _G.Config.FastAttack.Range then
                    table.insert(list, { enemy, part })
                end
            end
        end
    end

    function FastAttack:Attack()
        local _, _, RegisterAttack, RegisterHit, Enemies = CheckAndGetCoreComponents()
        local targets = {}

        if _G.Config.FastAttack.AttackNPC then
            CollectEnemies(targets, Enemies)
        end

        if _G.Config.FastAttack.AttackPlayers then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= Player and IsAlive(plr.Character) then
                    local part = GetRandomValidPart(plr.Character)
                    if part and Player:DistanceFromCharacter(part.Position) <= _G.Config.FastAttack.Range then
                        table.insert(targets, { plr.Character, part })
                    end
                end
            end
        end

        if #targets > 0 then
            RegisterAttack:FireServer(_G.Config.FastAttack.Delay)
            RegisterHit:FireServer(targets[1][2], targets)
        end
    end

    task.spawn(function()
        while true do
            task.wait(_G.Config.FastAttack.Delay)

            if _G.Config.FastAttack.Enabled then
                FastAttack:Attack()
            end
        end
    end)

    return FastAttack
end

local function InitFastAttack()
    if ENV.rz_FastAttack then
        return ENV.rz_FastAttack
    end
    ENV.rz_FastAttack = BuildFastAttack()
    return ENV.rz_FastAttack
end

