local ESPElements = {}

local function CleanupPlayerESP(player)
    local e = ESPElements[player.UserId]
    if not e then return end

    if e.NameHealthESP then e.NameHealthESP:Destroy() e.NameHealthESP = nil end
    if e.NameHealthUpdateConn then e.NameHealthUpdateConn:Disconnect() e.NameHealthUpdateConn = nil end
    if e.Tracer then e.Tracer:Remove() e.Tracer = nil end
    if e.TracerConn then e.TracerConn:Disconnect() e.TracerConn = nil end

    ESPElements[player.UserId] = nil
end

local function CreateNameDistanceESP(player)
    if not player.Character or not player.Character:FindFirstChild("Head") then return end
    local head = player.Character.Head
    local e = ESPElements[player.UserId] or {}

    if e.NameHealthESP then e.NameHealthESP:Destroy() end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NameDistanceESP"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, _G.Config["ESP"]["NameSize"], 0, _G.Config["ESP"]["NameSize"]/4)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = head

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = billboard
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.new(1,1,1)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamSemibold
    nameLabel.Size = UDim2.new(1,0,1,0)
    nameLabel.Text = player.Name

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not billboard.Parent or not LocalPlayer.Character or not player.Character then return end
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root and localRoot then
            if _G.Config.ESP.Enabled and _G.Config.ESP.NameDistance then
                nameLabel.Text = player.Name.." "..string.format("Distance:%.1f", (root.Position - localRoot.Position).Magnitude)
                billboard.Enabled = true
            else
                billboard.Enabled = false
            end
        end
    end)

    e.NameHealthESP = billboard
    e.NameHealthUpdateConn = conn
    ESPElements[player.UserId] = e
end

local function CreateHealthESP(player)
    if not player.Character or not player.Character:FindFirstChild("Humanoid") or not player.Character:FindFirstChild("Head") then return end
    local head = player.Character.Head
    local humanoid = player.Character.Humanoid
    local e = ESPElements[player.UserId] or {}

    if e.HealthESP then e.HealthESP:Destroy() end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "HealthESP"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, _G.Config["ESP"]["HealthSize"], 0, _G.Config["ESP"]["HealthSize"]/2)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = head

    local healthLabel = Instance.new("TextLabel")
    healthLabel.Parent = billboard
    healthLabel.BackgroundTransparency = 1
    healthLabel.TextScaled = true
    healthLabel.Font = Enum.Font.Gotham
    healthLabel.Size = UDim2.new(1,0,1,0)

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not billboard.Parent or not humanoid then return end
        if _G.Config.ESP.Enabled and _G.Config.ESP.Health then
            local hp = math.floor(humanoid.Health)
            local maxHp = math.floor(humanoid.MaxHealth)
            healthLabel.Text = string.format("Health:%d/%d", hp, maxHp)
            local p = hp/maxHp
            healthLabel.TextColor3 = p>0.7 and Color3.new(0,1,0) or p>0.3 and Color3.new(1,1,0) or Color3.new(1,0,0)
            billboard.Enabled = true
        else
            billboard.Enabled = false
        end
    end)

    e.HealthESP = billboard
    e.HealthUpdateConn = conn
    ESPElements[player.UserId] = e
end

local function CreateTracerESP(player)
    local e = ESPElements[player.UserId] or {}
    if e.Tracer then e.Tracer:Remove() end

    local tracer = Drawing.new("Line")
    tracer.Color = Color3.new(0,0,1)
    tracer.Thickness = 2
    tracer.Transparency = 0.8
    tracer.Visible = false

    local conn = RunService.RenderStepped:Connect(function()
        if not _G.Config.ESP.Enabled or not _G.Config.ESP.Tracer then
            tracer.Visible = false
            return
        end
        local char = player.Character
        local localChar = LocalPlayer.Character
        if char and localChar then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    tracer.Visible = true
                    tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                    tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                else
                    tracer.Visible = false
                end
            else
                tracer.Visible = false
            end
        else
            tracer.Visible = false
        end
    end)

    e.Tracer = tracer
    e.TracerConn = conn
    ESPElements[player.UserId] = e
end

local function UpdatePlayerESP(player)
    if player == LocalPlayer then return end
    if not player.Character then CleanupPlayerESP(player) return end
    if _G.Config.ESP.Enabled == true then
        if _G.Config.ESP.NameDistance then CreateNameDistanceESP(player) end
        if _G.Config.ESP.Health then CreateHealthESP(player) end
        if _G.Config.ESP.Tracer then CreateTracerESP(player) end
    else
        CleanupPlayerESP(player)
    end
end

function UpdateAllESP()
    for _, p in pairs(Players:GetPlayers()) do
        UpdatePlayerESP(p)
    end
end

local function BindPlayerESP(PlayerObj)
    if PlayerObj == LocalPlayer then
        return
