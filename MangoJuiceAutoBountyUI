local function StartAutoV3()
    if autoV3Conn then return end

    autoV3Conn = RunService.Heartbeat:Connect(function()
        if not _G.Config.Race.AutoV3 then
            autoV3Conn:Disconnect()
            autoV3Conn = nil
            return
        end

        if os.clock() - lastV3 < V3Cooldown then return end
        lastV3 = os.clock()

        pcall(function()
            CommE:FireServer("ActivateAbility")
        end)
    end)
end

local function findAwakeningTool()
    local char = LocalPlayer.Character
    if not char then return end

    return char:FindFirstChild("Awakening")
        or LocalPlayer.Backpack:FindFirstChild("Awakening") or nil
end

local function StartAutoV4()
    if autoV4Conn then return end

    autoV4Conn = RunService.Heartbeat:Connect(function()
        if not _G.Config.Race.AutoV4 then
            autoV4Conn:Disconnect()
            autoV4Conn = nil
            return
        end

        if os.clock() - lastV4 < V4Cooldown then return end
        lastV4 = os.clock()

        local tool = findAwakeningTool()
        if not tool then return end

        local remote = tool:FindFirstChildWhichIsA("RemoteFunction")
        if not remote then return end

        pcall(function()
            remote:InvokeServer(true)
        end)
    end)
end

