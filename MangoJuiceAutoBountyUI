local function EncodeConfig()
    local success, json = pcall(function()
        return HttpService:JSONEncode(_G.Config)
    end)
    if success then
        return json
    else
        warn("Failed to encode Config to JSON")
        return "{}"
    end
end

function SaveConfig()
    if not writefile then print("Can Not Save") return end
    local json = EncodeConfig()
    if json == LastSaved then return end

    pcall(writefile, ConfigFile, json)
    LastSaved = json
end

function LoadConfig()
    if not readfile or not isfile then print("Can Not Load") return end
    if not isfile(ConfigFile) then return end

    local data
    local success = pcall(function()
        data = readfile(ConfigFile)
    end)
    if not success or not data then return end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(data)
    end)
    if not ok or type(decoded) ~= "table" then
        warn("Config JSON is invalid")
        return
    end

    for k,v in pairs(decoded) do
        _G.Config[k] = v
    end

    LastSaved = data
end

function ResetConfig()
        if delfile and isfile and isfile(ConfigFile) then
            pcall(delfile, ConfigFile)
        end
end 

